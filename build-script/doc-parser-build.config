# build.config
# 도커 레지스트리
DOCKER_REGISTRY=mncregistry:30500

# 이미지 이름
IMAGE_NAME=doc-parser-preprocessor

# 버전 (git tag, 브랜치 이름, 날짜 등으로 교체 가능)
IMAGE_VERSION=1.3.6.3

# 실제 Dockerfile 위치 (루트 기준)
DOCKERFILE_PATH=genon/preprocessor/docker/Dockerfile

# 빌드 후 push 할지 여부
PUSH_IMAGE=true

# USER, GROUP
APP_UID=3000
APP_GID=3000
APP_UNAME=genos
APP_GNAME=genos

# NLTK packages (comma-separated). Use "all" to download everything.
APP_NLTK_PACKAGES=punkt,stopwords,averaged_perceptron_tagger,averaged_perceptron_tagger_eng,wordnet,omw-1.4

# HuggingFace Access Token (Private Repo 접근용)
# 실제 토큰은 build-script/doc-parser-build.config.local 파일에 설정하세요. (Git에 커밋되지 않음)
# 예시: echo "HF_TOKEN=hf_your_token_here" > build-script/doc-parser-build.config.local
HF_TOKEN=