# build.config
# 도커 레지스트리
DOCKER_REGISTRY=mncregistry:30500

# 이미지 이름
IMAGE_NAME=doc-parser-preprocessor

# 버전 (git tag, 브랜치 이름, 날짜 등으로 교체 가능)
IMAGE_VERSION=1.3.6.3

# 빌드 variant (이슈 #199, #236 — standard / synap 두 빌드 산출물 분리)
# ⚠️  반드시 standard 또는 synap 중 하나로 명시할 것.
#     비워둔 채로 doc-parser-build.sh 를 실행하면 즉시 에러로 중단된다
#     (의도치 않게 유료 SDK 가 포함될 위험을 막기 위함).
#     자세한 차이/배경은 ../genon/README.md 의 "전처리기 빌드 및 등록" 2번 항목 참고.
#   standard  — 기본 산출물. LibreOffice + rhwp(컨테이너 내 바이너리) 만 포함.
#               PDF SDK 미포함(다운로드 단계 자체가 없음). 외부 배포 / 라이선스 미보유 환경.
#   synap       — 위 + 유료 PDF SDK(Synap) 포함 (PDF_SDK_TOKEN 으로 다운로드).
#               HWP → PDF 변환 chain 이 pdf_sdk → rhwp → libreoffice 순.
#               ⚠️ synap 빌드/배포는 AI Search 팀 문의 필요 (README "전처리기 빌드 및 등록" 참고).
# 예시:
#   BUILD_VARIANT=synap
BUILD_VARIANT=

# 하드웨어 variant (이슈 #210 — GPU / CPU 두 빌드 산출물 분리)
# ⚠️  반드시 gpu 또는 cpu 중 하나로 명시할 것. 비워둔 채 빌드 실행 시 즉시 에러.
#   gpu  — uv.lock 기준 그대로. torch CUDA wheel + nvidia-* / triton 포함.
#   cpu  — builder 단계에서 torch / torchvision 을 CPU wheel 로 재설치하고
#          nvidia-* / triton 패키지를 제거 (이미지 경량화).
# 예시:
#   HW_VARIANT=gpu
HW_VARIANT=

# rhwp / LibreOffice 설치 여부 (이슈 #286 — 위 패키지 미사용 사이트용)
# ⚠️  반드시 true 또는 false 로만 입력할 것 (다른 문자열이면 빌드가 깨진다).
#   INSTALL_LIBREOFFICE=true  (기본) — LibreOffice + Java + H2Orestart 확장 포함.
#                       false       — 위 전부 미설치. docx/ppt/xls 등 오피스→PDF 변환 불가.
#   INSTALL_RHWP=true         (기본) — rhwp 바이너리(컨테이너 내 Rust 빌드) 포함.
#                       false       — rhwp 미포함. HWP/HWPX→PDF 의 rhwp 경로 제거.
#
# 동작 영향 (HWP→PDF chain 은 가용 backend 만 자동 등록 — 미설치 backend 는 graceful 제외):
#   - standard 에서 둘 다 false → 변환 backend 가 0개. 전처리기별로 영향이 다르다:
#       · 적재형(지능형): 비-PDF 입력을 내부 PDF 변환 후 파싱 → 변환기 없으면 처리 불가.
#         PDF 로 변환된 문서를 입력해야 함.
#       · 첨부형/변환형/파싱형: HWP 는 내장 HWP SDK(항상 포함), docx/ppt 는 원본을
#         직접 파싱하므로 변환 backend 없이도 동작 (영향 적음).
#   - synap 은 PDF SDK 가 1순위라 둘 다 false 여도 docx/ppt 등은 PDF SDK 로 변환됨.
#
# 태그 반영: off 면 이미지 태그 끝에 -nolibre / -norhwp 가 자동으로 붙는다 (이슈 #286).
#   예) cpu+standard + 둘 다 off → :1.3.6.3-nolibre-norhwp
#   → off 이미지가 운영 이미지(둘 다 on)와 같은 태그로 push 돼 덮어쓰는 사고를 자동 차단.
#   (둘 다 on=기본이면 접미사 없음. register.config 에도 동일 값을 넣어야 태그가 일치한다.)
INSTALL_LIBREOFFICE=true
INSTALL_RHWP=true

# 빌드 직후 컨테이너에서 smoke test 실행 (torch variant 검증 + 샘플 1건 파싱)
SMOKE_TEST=true
# 사용할 샘플 파일명 (genon/preprocessor/sample_files/ 하위)
SMOKE_TEST_FILE=pdf_sample.pdf

# CPU 빌드 시 사용할 torch wheel index URL (필요 시 사내 미러로 교체)
TORCH_CPU_INDEX_URL=https://download.pytorch.org/whl/cpu

# 빌드 후 push 할지 여부
PUSH_IMAGE=true

# USER, GROUP
APP_UID=3000
APP_GID=3000
APP_UNAME=genos
APP_GNAME=genos

# NLTK packages (comma-separated). Use "all" to download everything.
APP_NLTK_PACKAGES=punkt,stopwords,averaged_perceptron_tagger,averaged_perceptron_tagger_eng,wordnet,omw-1.4

# HuggingFace Access Tokens (Private Repo 접근용, 이슈 #199 — SDK 별 fine-grained 분리)
# ⚠️  두 값 모두 여기에 직접 입력하지 말 것 — 반드시 hf_private_token.env 파일에만
#     설정한다 (Git 미추적). 발급 방법은 ../genon/README.md "전처리기 빌드 및 등록"
#     1번/2번 항목의 fine-grained 토큰 안내 참고.
#
#   HWP_SDK_TOKEN  — HeechanKim-Genon/hwp_sdk 전용 read 토큰 (두 variant 모두 필수)
#   PDF_SDK_TOKEN  — HeechanKim-Genon/pdf_sdk 전용 read 토큰 (synap 일 때만 필수, AI Search 팀 발급)
#
# 예시 (한 줄로):
#   echo "HWP_SDK_TOKEN=hf_xxx" >> build-script/hf_private_token.env
#   echo "PDF_SDK_TOKEN=hf_yyy" >> build-script/hf_private_token.env
HWP_SDK_TOKEN=SET_IN_hf_private_token.env
PDF_SDK_TOKEN=SET_IN_hf_private_token.env