# build.config — doc-parser 코드서빙 base 이미지 빌드 설정.
#
# build context = repo 루트 (build.sh 가 ROOT_DIR=repo 루트 사용).
# genon/preprocessor/resources 와 build-script/hf_private_token.env 를 재사용한다 (자기완결 아님).
#
# 코드 서빙 동작: 시스템이 이 base 이미지를 띄운 뒤 런타임에 git 소스를 /app/src/service 로
#   clone 하고 main.py(facade)를 실행한다. facade 의 무거운 deps + 다운로드 아티팩트
#   (모델/HWP SDK/rhwp/H2Orestart/폰트/NLTK/EasyOCR)는 콜드스타트/오프라인 대응을 위해
#   이 base 이미지에 빌드 시점에 pre-bake 한다 (Dockerfile.standard 와 full parity).

# 도커 레지스트리
DOCKER_REGISTRY=mncregistry:30500

# 이미지 이름 (최종 태그: ${DOCKER_REGISTRY}/mnc/${IMAGE_NAME}:...)
IMAGE_NAME=doc-parser-serving

# 버전
IMAGE_VERSION=0.1.0

# 하드웨어 variant (gpu / cpu). 비우면 build.sh 에서 즉시 에러.
#   cpu  — Dockerfile      (python:3.12-slim, CPU torch). 태그 ${IMAGE_VERSION}
#   gpu  — Dockerfile.gpu  (nvidia/cuda 12.4.1, torch cu124). 태그 ${IMAGE_VERSION}-gpu
HW_VARIANT=

# 빌드 직후 smoke test (venv import + torch variant + 아티팩트 존재 + docling_parse 설치 위치 검증)
SMOKE_TEST=true

# 빌드 후 push 여부
PUSH_IMAGE=true

# CPU 빌드 시 torch CPU wheel index (필요 시 사내 미러로 교체)
TORCH_CPU_INDEX_URL=https://download.pytorch.org/whl/cpu

# NLTK 패키지 (쉼표 구분, "all" 도 가능). Dockerfile.standard 기본은 all.
NLTK_PACKAGES=punkt,stopwords,averaged_perceptron_tagger,averaged_perceptron_tagger_eng,wordnet,omw-1.4

# rhwp(genos-rhwp) 빌드 git ref
RHWP_GIT_REF=genos/main

# USER, GROUP
APP_UID=3000
APP_GID=3000
APP_UNAME=genos
APP_GNAME=genos

# HWP SDK 다운로드용 HF fine-grained read 토큰 (HeechanKim-Genon/hwp_sdk).
# ⚠️ 여기에 직접 입력하지 말 것 — 반드시 build-script/hf_private_token.env 에만 설정 (Git 미추적).
#   echo "HWP_SDK_TOKEN=hf_xxx" >> build-script/hf_private_token.env
# (전처리기 빌드와 동일 토큰/파일 재사용. genon/README "전처리기 빌드 및 등록" 1번 참고.)
HWP_SDK_TOKEN=SET_IN_hf_private_token.env
