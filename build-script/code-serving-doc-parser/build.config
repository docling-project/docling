# build.config — doc-parser 코드서빙 base 이미지 빌드 설정.
#
# 이 폴더(build-script/code-serving-doc-parser)는 자기완결(self-contained)이다.
# build.sh 는 이 폴더를 build context 로 사용하며 genon/code-serving / repo 루트를 참조하지 않는다.
#
# 코드 서빙 동작: 시스템이 이 base 이미지를 띄운 뒤 런타임에 현재 git 소스를
#   /app/src/service 로 clone 하고 requirements.txt 로 환경 구성 후 main.py 를 실행한다.
#   무거운 deps(docling/easyocr/transformers 등)는 콜드스타트 단축을 위해 이 base 이미지에
#   빌드 시점에 pre-bake 한다. 의존성은 pyproject.toml(genon/preprocessor uv 정보 기반)에
#   선언되어 있고 Dockerfile 의 `uv pip install .` 로 설치된다.

# 도커 레지스트리
DOCKER_REGISTRY=mncregistry:30500

# 이미지 이름 (최종 태그: ${DOCKER_REGISTRY}/mnc/${IMAGE_NAME}:...)
IMAGE_NAME=doc-parser-serving

# 버전 (필요 시 교체)
IMAGE_VERSION=0.1.0

# 하드웨어 variant (gpu / cpu 두 빌드 산출물 분리)
# ⚠️  반드시 gpu 또는 cpu 중 하나로 명시할 것. 비워둔 채 빌드 실행 시 즉시 에러.
#   cpu  — Dockerfile (python:3.12-slim, CPU torch). 기본 산출물.
#   gpu  — Dockerfile.gpu (nvidia/cuda 12.4.1 + torch cu124).
# 최종 태그: cpu 는 접미사 없이 ${IMAGE_VERSION}, gpu 는 ${IMAGE_VERSION}-gpu.
# 예시:
#   HW_VARIANT=cpu
HW_VARIANT=

# 빌드 직후 컨테이너에서 smoke test 실행
# (venv 의존성 import + torch GPU/CPU variant 검증. base 이미지엔 repo 소스가 없어
#  full parse 는 불가하므로 의존성/torch 분기만 확인한다.)
SMOKE_TEST=true

# 빌드 후 push 할지 여부
PUSH_IMAGE=true

# USER, GROUP
APP_UID=3000
APP_GID=3000
APP_UNAME=genos
APP_GNAME=genos
