# 빌드 컨텍스트: 프로젝트 루트
CONTEXT=.

# Dockerfile 위치 (B300 전용)
DOCKERFILE=genon/serving/paddle/docker/Dockerfile-b300

# 이미지 이름/태그
#   기존 cu126 이미지(doc-parser-ocr) 와 구분하기 위해 -b300 접미사를 사용한다.
IMAGE_NAME=doc-parser-ocr-b300
IMAGE_TAG=0.0.0

# 푸시할 레지스트리 (없으면 빈값)
REGISTRY=mncregistry:30500

# Paddle extra index (B300 = Blackwell → cu129)
PADDLE_EXTRA_INDEX_URL=https://www.paddlepaddle.org.cn/packages/stable/cu129/
