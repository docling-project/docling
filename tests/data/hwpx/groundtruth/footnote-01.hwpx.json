      "label": "footnote",
      "prov": [],
      "orig": "썀쌍둥이란 샴이란",
      "text": "썀쌍둥이란 샴이란"
    },
    {
      "self_ref": "#/texts/18",
      "parent": {
        "$ref": "#/groups/4"
      },
      "children": [
        {
          "$ref": "#/groups/7"
        }
      ],
      "content_layer": "body",
      "label": "list_item",
      "prov": [],
      "orig": "문제점 분석",
      "text": "문제점 분석",
