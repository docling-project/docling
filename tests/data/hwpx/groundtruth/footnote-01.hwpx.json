      "label": "list_item",
      "prov": [],
      "orig": "시제품 제작 시간과 비용 절감 및 이를 통한 제품 혁신의 가속화",
      "text": "시제품 제작 시간과 비용 절감 및 이를 통한 제품 혁신의 가속화",
      "enumerated": false,
