      "orig": "-3 \u067e\u0630\u064a\u0631\u0634 \u062f\u0631 \u0628\u0648\u0631\u0633 \u062a\u0627\u0631\u064a\u062e \u0627\u0631\u0627\u0626\u0647 \u0645\u062f\u0627\u0631\u06a9 1403/09/19 \u062a\u0627\u0631\u064a\u062e \u067e\u0630\u064a\u0631\u0634 1403/10/04 \u0634\u0645\u0627\u0631\u0647 \u062c\u0644\u0633\u0647 \u06a9\u0645\u064a\u062a\u0647 \u0639\u0631\u0636\u0647 436 \u062a\u0627\u0631\u064a\u062e \u062f\u0631\u062c \u0627\u0645\u064a\u062f\u0646\u0627\u0645\u0647 1403/10/05 \u0645\u0634\u0627\u0648\u0631 \u067e\u0630\u064a\u0631\u0634 \u06a9\u0627\u0631\u06af\u0632\u0627\u0631\u06cc \u0622\u0631\u0645\u0648\u0646 \u0628\u0648\u0631\u0633 \u0646\u062d\u0648\u0629 \u062a\u0639\u064a\u064a\u0646 \u0642\u064a\u0645\u062a \u067e\u0627\u064a\u0647 \u067e\u0633 \u0627\u0632 \u067e\u0630\u064a\u0631\u0634 \u06a9\u0627\u0644\u0627 \u062f\u0631 \u0628\u0648\u0631\u0633 \u0628\u0631 \u0627\u0633\u0627\u0633 \u0642\u064a\u0645\u062a \u0647\u0627\u06cc  \u062c\u0647\u0627\u0646\u06cc \u062d\u062f\u0627\u0642\u0644 \u062f\u0631\u0635\u062f \u0639\u0631\u0636\u0647 \u0627\u0632 \u062a\u0648\u0644\u064a\u062f/ \u06a9\u0644 \u0641\u0631\u0648\u0634/ \u0641\u0631\u0648\u0634 \u062f\u0627\u062e\u0644\u06cc \u062d\u062f\u0627\u0642\u0644 %50 \u0627\u0632 \u062a\u0648\u0644\u064a\u062f \u0633\u0627\u0644\u064a\u0627\u0646\u0647 \u064a\u0627 47.500 \u062a\u0646 \u062e\u0637\u0627\u06cc \u0645\u062c\u0627\u0632 \u062a\u062d\u0648\u064a\u0644 5% \u0622\u062e\u0631\u064a\u0646 \u0645\u062d\u0645\u0648\u0644\u0647 \u0642\u0627\u0628\u0644 \u062a\u062d\u0648\u064a\u0644",
      "text": "-3 \u067e\u0630\u064a\u0631\u0634 \u062f\u0631 \u0628\u0648\u0631\u0633 \u062a\u0627\u0631\u064a\u062e \u0627\u0631\u0627\u0626\u0647 \u0645\u062f\u0627\u0631\u06a9 1403/09/19 \u062a\u0627\u0631\u064a\u062e \u067e\u0630\u064a\u0631\u0634 1403/10/04 \u0634\u0645\u0627\u0631\u0647 \u062c\u0644\u0633\u0647 \u06a9\u0645\u064a\u062a\u0647 \u0639\u0631\u0636\u0647 436 \u062a\u0627\u0631\u064a\u062e \u062f\u0631\u062c \u0627\u0645\u064a\u062f\u0646\u0627\u0645\u0647 1403/10/05 \u0645\u0634\u0627\u0648\u0631 \u067e\u0630\u064a\u0631\u0634 \u06a9\u0627\u0631\u06af\u0632\u0627\u0631\u06cc \u0622\u0631\u0645\u0648\u0646 \u0628\u0648\u0631\u0633 \u0646\u062d\u0648\u0629 \u062a\u0639\u064a\u064a\u0646 \u0642\u064a\u0645\u062a \u067e\u0627\u064a\u0647 \u067e\u0633 \u0627\u0632 \u067e\u0630\u064a\u0631\u0634 \u06a9\u0627\u0644\u0627 \u062f\u0631 \u0628\u0648\u0631\u0633 \u0628\u0631 \u0627\u0633\u0627\u0633 \u0642\u064a\u0645\u062a \u0647\u0627\u06cc  \u062c\u0647\u0627\u0646\u06cc \u062d\u062f\u0627\u0642\u0644 \u062f\u0631\u0635\u062f \u0639\u0631\u0636\u0647 \u0627\u0632 \u062a\u0648\u0644\u064a\u062f/ \u06a9\u0644 \u0641\u0631\u0648\u0634/ \u0641\u0631\u0648\u0634 \u062f\u0627\u062e\u0644\u06cc \u062d\u062f\u0627\u0642\u0644 %50 \u0627\u0632 \u062a\u0648\u0644\u064a\u062f \u0633\u0627\u0644\u064a\u0627\u0646\u0647 \u064a\u0627 47.500 \u062a\u0646 \u062e\u0637\u0627\u06cc \u0645\u062c\u0627\u0632 \u062a\u062d\u0648\u064a\u0644 5% \u0622\u062e\u0631\u064a\u0646 \u0645\u062d\u0645\u0648\u0644\u0647 \u0642\u0627\u0628\u0644 \u062a\u062d\u0648\u064a\u0644"
