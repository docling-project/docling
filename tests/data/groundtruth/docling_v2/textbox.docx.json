      "content_layer": "body",
      "label": "text",
      "prov": [],
      "orig": "Infectious Disease Reporting Procedure for the 113th Academic Year Kindergarten",
      "text": "Infectious Disease Reporting Procedure for the 113th Academic Year Kindergarten",
      "formatting": {
        "bold": true
      }
    },
    {
      "self_ref": "#/texts/2",
