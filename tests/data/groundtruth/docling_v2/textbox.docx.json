      },
      "children": [],
      "content_layer": "body",
      "label": "text",
      "prov": [],
      "orig": "Student falls ill",
      "text": "Student falls ill"
    },
    {
      "self_ref": "#/texts/4",
      "parent": {
        "$ref": "#/body"
      },
      "children": [],
      "content_layer": "body",
      "label": "text",
      "prov": [],
      "orig": "Suggested Reportable Symptoms:＊ Fever＊ Cough＊ Diarrhea＊ Vomiting＊ Rash＊ Blisters＊ Headache＊ Sore throat",
      "text": "Suggested Reportable Symptoms:＊ Fever＊ Cough＊ Diarrhea＊ Vomiting＊ Rash＊ Blisters＊ Headache＊ Sore throat"
    },
    {
      "self_ref": "#/texts/5",
      "parent": {
        "$ref": "#/body"
      },
      "children": [],
      "content_layer": "body",
