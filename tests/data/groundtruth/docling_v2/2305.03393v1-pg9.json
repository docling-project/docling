      ],
      "orig": "order to compute the TED score. Inference timing results for all experiments\nwere obtained from the same machine on a single core with AMD EPYC 7763\nCPU @2.45 GHz.",
      "text": "order to compute the TED score. Inference timing results for all experiments\nwere obtained from the same machine on a single core with AMD EPYC 7763\nCPU @2.45 GHz."
    },
    {
      "self_ref": "#/texts/2",
