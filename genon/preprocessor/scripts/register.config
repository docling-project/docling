# 필수
REGISTRY_NAME="mncregistry:30500/"
IMAGE_NAME="mnc/doc-parser-preprocessor"
DESCRIPTION="unified-preprocessor"

# ── 등록 대상 이미지 태그 구성 ────────────────────────────────────────────────
# 아래 세 값을 조합해서 최종 IMAGE_TAG 를 만든다 (이슈 #236, build-script 와 동일 컨벤션):
#   - 기본 조합(cpu + standard) → IMAGE_TAG=${IMAGE_VERSION}        (접미사 생략)
#   - 그 외 조합               → IMAGE_TAG=${IMAGE_VERSION}-${HW_VARIANT}-${BUILD_VARIANT}
#   예) IMAGE_VERSION=2.1.5, HW_VARIANT=gpu, BUILD_VARIANT=synap → 2.1.5-gpu-synap
#       IMAGE_VERSION=2.1.5, HW_VARIANT=cpu, BUILD_VARIANT=standard → 2.1.5
#
# ⚠️  세 값 모두 build-script/doc-parser-build.config 와 **동일한 값**으로 둘 것.
#     (운영자가 빌드와 등록에서 같은 값을 일관되게 사용)
IMAGE_VERSION="2.1.5"
BUILD_VARIANT="standard"   # standard | synap
HW_VARIANT="cpu"           # gpu | cpu

# K8s / DB 파드 위치
K8S_NAMESPACE="llmops"
MARIADB_POD="mariadb-mariadb-galera-0"
# 파드에 컨테이너가 여러 개면 선택 (없으면 비워두기)
# MARIADB_CONTAINER="mariadb"

# 입력 기본값(옵션): 프롬프트에서 Enter 시 사용
DEFAULT_MYSQL_USER="root"
DEFAULT_MYSQL_PASS=""   # 비워두면 프롬프트에서 암호 입력받음 사이트에서 사용 시 입력하지 마시오.
