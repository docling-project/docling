# Copy to .env (the file `.env` is gitignored) and fill in your secrets.
# tests/conftest.py auto-loads .env so secrets aren't required on the shell.
# Existing environment variables (e.g. those injected by docker/k8s) take
# precedence over .env, so this file is purely a local-dev convenience.

# Upstage Document Digitization OCR API key.
# Required to run the live tests in tests/test_upstage_ocr_model.py
# (test_live_*) and tests/test_e2e_ocr_conversion.py::test_e2e_upstage_conversion.
# Without this, those tests are automatically skipped.
# Get a key at https://console.upstage.ai
UPSTAGE_API_KEY=

# Generate canonical test reference data when running pytest.
# Used by tests/test_data_gen_flag.py. Set to 1 to regenerate.
# DOCLING_GEN_TEST_DATA=
